# --- Secrets / environment (NEVER commit these) ---
# The Supabase service_role key and other secrets are passed via env vars,
# and any local .env file must stay out of git.
.env
.env.*
!.env.example

# --- Python (geocode.py / import_to_supabase.py) ---
__pycache__/
*.py[cod]

# --- Node / Next.js (for the upcoming app) ---
node_modules/
.next/
out/
build/
*.log

# --- macOS ---
.DS_Store

# --- USAJOBS exploration output (DO NOT COMMIT yet) ---
# fetch_jobs.py writes this raw API dump while we explore the "currently hiring"
# feature. Keep it out of the public repo until we've decided how (and whether)
# to use it. The script itself is fine to commit; this output is not.
fire_jobs_raw.json
# Cache of geocoded job duty-station towns (proximity-matching dry-run).
job_geocache.json

# --- Third-party data pending permission (DO NOT COMMIT) ---
# The "Wildland Fire Handcrew Atlas" KML/KMZ was exported from someone else's
# Google My Maps. We don't have permission to use or publish it yet, so keep it
# (and any extracted copies) out of the public repo. Permission to USE the data
# is now secured, but we don't republish the source file or raw extracts.
*.kml
*.kmz
# Dry-run review CSVs derived from the Atlas (see MERGE_PLAN.md). Local review
# artifacts, not product — keep out of git until the import is designed.
merge_review_*.csv

# --- Claude Code local (machine-specific) settings ---
# Keep the shared subagent (.claude/agents/) tracked, but not local settings.
.claude/settings.local.json
